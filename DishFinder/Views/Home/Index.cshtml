@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">
    <div class="p-4 mb-4 bg-light rounded-3 border">
        <h1 class="display-5 fw-bold">DishFinder Home</h1>
        <p class="lead">
            Cloud-based restaurant menu processing and search platform.
            Upload menu images, process them into searchable items, and translate confirmed menu entries.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">Upload Menu</h4>
                    <p class="card-text">
                        Upload one or more restaurant menu images for OCR and parsing.
                    </p>
                    <a asp-controller="Upload" asp-action="Create" class="btn btn-primary">
                        Go to Upload
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">Create Restaurant</h4>
                    <p class="card-text">
                        Add a new restaurant before uploading or managing menus.
                    </p>
                    <a asp-controller="Restaurants" asp-action="Create" class="btn btn-primary">
                        Create Restaurant
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">Catalog</h4>
                    <p class="card-text">
                        Search confirmed menu items, sort by price, and translate visible entries.
                    </p>
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">
                        Open Catalog
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title">Quick Search</h4>
            <form asp-controller="Catalog" asp-action="Index" method="get" class="row g-2">
                <div class="col-md-8">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search Pasta, Burger, Steak..." />
                </div>
                <div class="col-md-3">
                    <select name="sortOrder" class="form-select">
                        <option value="price_asc">Lowest price first</option>
                        <option value="price_desc">Highest price first</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-success w-100">Go</button>
                </div>
            </form>
        </div>
    </div>
</div>