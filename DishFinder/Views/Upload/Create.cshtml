@model DishFinder.Models.MenuUploadViewModel

@{
    ViewData["Title"] = "Create Menu Upload";
}

<h2>Create Menu Upload</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<form asp-controller="Upload" asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label asp-for="RestaurantId" class="form-label"></label>
        <select asp-for="RestaurantId" asp-items="Model.Restaurants" class="form-select">
            <option value="">Select a restaurant</option>
        </select>
        <span asp-validation-for="RestaurantId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuTitle" class="form-label"></label>
        <input asp-for="MenuTitle" class="form-control" />
        <span asp-validation-for="MenuTitle" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuImage" class="form-label"></label>
        <input asp-for="MenuImage" type="file" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
        <span asp-validation-for="MenuImage" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Continue</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}