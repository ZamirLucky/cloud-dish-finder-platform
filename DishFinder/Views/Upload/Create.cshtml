@model DishFinder.Models.MenuUploadViewModel

@{
    ViewData["Title"] = "Upload Menu Images";
}

<h2>Upload Menu Images</h2>

<div id="messageArea"></div>

<form id="uploadForm"
      method="post"
      enctype="multipart/form-data"
      data-start-upload-url="@Url.Action("StartMenuUpload", "Upload")"
      data-upload-single-url="@Url.Action("UploadSingleImage", "Upload")">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="RestaurantId" class="form-label"></label>
        <select asp-for="RestaurantId" asp-items="Model.Restaurants" class="form-select">
            <option value="">Select a restaurant</option>
        </select>
        <span asp-validation-for="RestaurantId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuTitle" class="form-label"></label>
        <input asp-for="MenuTitle" class="form-control" />
        <span asp-validation-for="MenuTitle" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuImages" class="form-label"></label>
        <input asp-for="MenuImages"
               id="menuImages"
               type="file"
               class="form-control"
               accept=".jpg,.jpeg,.png,.gif"
               multiple />
        <span asp-validation-for="MenuImages" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Upload</button>
</form>

<hr />

<div id="progressContainer"></div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/upload-create.js" asp-append-version="true"></script>
}