@model DishFinder.Models.CatalogIndexViewModel

@{
    ViewData["Title"] = "Catalog";

    var totalItems = Model.Items?.Count ?? 0;
    var restaurantCount = Model.Items?
        .Where(x => !string.IsNullOrWhiteSpace(x.RestaurantName))
        .Select(x => x.RestaurantName)
        .Distinct()
        .Count() ?? 0;
    var menuCount = Model.Items?
        .Where(x => !string.IsNullOrWhiteSpace(x.MenuTitle))
        .Select(x => $"{x.RestaurantId}:{x.MenuId}")
        .Distinct()
        .Count() ?? 0;
    var hasSearch = !string.IsNullOrWhiteSpace(Model.SearchTerm);
}

<style>
    .catalog-page {
        --catalog-border: #e5e7eb;
        --catalog-muted: #6b7280;
        --catalog-ink: #111827;
        --catalog-soft: #f8fafc;
        --catalog-primary: #0d6efd;
        --catalog-success: #198754;
        padding-bottom: 1rem;
    }

    .catalog-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 54%, #0284c7 100%);
        border-radius: 1.25rem;
        color: #ffffff;
        padding: 2rem;
        box-shadow: 0 1rem 2.5rem rgba(15, 23, 42, 0.18);
        margin-bottom: 1.5rem;
    }

    .catalog-hero h1 {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        margin-bottom: .5rem;
    }

    .catalog-hero p {
        color: rgba(255, 255, 255, .84);
        max-width: 760px;
        margin-bottom: 0;
    }

    .catalog-stat-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .catalog-stat-card,
    .catalog-filter-card,
    .catalog-table-card,
    .empty-state-card {
        background: #ffffff;
        border: 1px solid var(--catalog-border);
        border-radius: 1rem;
        box-shadow: 0 .75rem 1.75rem rgba(15, 23, 42, .06);
    }

    .catalog-stat-card {
        padding: 1rem 1.25rem;
    }

    .catalog-stat-label {
        color: var(--catalog-muted);
        font-size: .82rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: .2rem;
    }

    .catalog-stat-value {
        color: var(--catalog-ink);
        font-size: 1.65rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .catalog-filter-card {
        padding: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .catalog-filter-grid {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(200px, 260px) auto auto;
        gap: 1rem;
        align-items: end;
    }

    .catalog-label {
        color: #374151;
        font-weight: 700;
        margin-bottom: .4rem;
    }

    .catalog-table-card {
        overflow: hidden;
    }

    .catalog-table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--catalog-border);
        background: var(--catalog-soft);
    }

    .catalog-table-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        color: var(--catalog-ink);
    }

    .catalog-table-subtitle {
        color: var(--catalog-muted);
        font-size: .9rem;
    }

    .catalog-table-wrapper {
        width: 100%;
        overflow-x: auto;
        overflow-y: visible;
    }

    .catalog-table {
        min-width: 1120px;
    }

    .catalog-table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #ffffff;
        color: #374151;
        border-bottom: 1px solid var(--catalog-border);
        font-size: .78rem;
        letter-spacing: .06em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .catalog-table tbody tr {
        transition: background-color .15s ease, box-shadow .15s ease;
    }

    .catalog-table tbody tr:hover {
        background: #f9fbff;
    }

    .restaurant-name {
        font-weight: 800;
        color: var(--catalog-ink);
    }

    .menu-title-text,
    .section-text,
    .item-name-text,
    .description-text {
        overflow-wrap: anywhere;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .25rem .6rem;
        background: #eef2ff;
        color: #3730a3;
        font-size: .8rem;
        font-weight: 700;
    }

    .item-name-text {
        display: inline-block;
        font-weight: 800;
        color: #111827;
        line-height: 1.35;
    }

    .description-text {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        color: #4b5563;
        max-width: 560px;
        line-height: 1.45;
    }

    .price-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 74px;
        border-radius: 999px;
        padding: .35rem .75rem;
        background: #ecfdf5;
        color: #047857;
        font-weight: 800;
        white-space: nowrap;
    }

    .translate-cell {
        width: 190px;
    }

    .translation-panel {
        display: grid;
        gap: .5rem;
        min-width: 160px;
    }

    .translation-result {
        min-height: 1.25rem;
        font-size: .86rem;
        font-weight: 700;
        color: var(--catalog-muted);
    }

    .translation-result.success {
        color: var(--catalog-success);
    }

    .translation-result.error {
        color: #dc3545;
    }

    .translation-result.working {
        color: var(--catalog-primary);
    }

    .empty-state-card {
        padding: 2.5rem 1.5rem;
        text-align: center;
    }

    .empty-state-card h3 {
        font-weight: 800;
        color: var(--catalog-ink);
        margin-bottom: .5rem;
    }

    .empty-state-card p {
        color: var(--catalog-muted);
        margin-bottom: 0;
    }

    @@media (max-width: 992px) {
        .catalog-stat-grid {
            grid-template-columns: 1fr;
        }

        .catalog-filter-grid {
            grid-template-columns: 1fr;
        }

        .catalog-filter-grid .btn {
            width: 100%;
        }
    }
</style>

<div class="catalog-page">
    <section class="catalog-hero">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <h1>Catalog</h1>
                <p>
                    Search confirmed restaurant menu items, compare prices, and translate visible menu details directly from the catalog.
                </p>
            </div>
            <div class="align-self-lg-end">
                <span class="badge rounded-pill text-bg-light px-3 py-2">Confirmed menu entries</span>
            </div>
        </div>
    </section>

    <section class="catalog-stat-grid" aria-label="Catalog summary">
        <div class="catalog-stat-card">
            <div class="catalog-stat-label">Items shown</div>
            <div class="catalog-stat-value">@totalItems</div>
        </div>
        <div class="catalog-stat-card">
            <div class="catalog-stat-label">Restaurants</div>
            <div class="catalog-stat-value">@restaurantCount</div>
        </div>
        <div class="catalog-stat-card">
            <div class="catalog-stat-label">Menus</div>
            <div class="catalog-stat-value">@menuCount</div>
        </div>
    </section>

    <form method="get" asp-controller="Catalog" asp-action="Index" class="catalog-filter-card">
        <div class="catalog-filter-grid">
            <div>
                <label for="searchTerm" class="form-label catalog-label">Search</label>
                <input id="searchTerm"
                       class="form-control form-control-lg"
                       type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       placeholder="Search pasta, burger, steak, section, restaurant..." />
            </div>

            <div>
                <label for="sortOrder" class="form-label catalog-label">Sort by price</label>
                <select id="sortOrder" name="sortOrder" class="form-select form-select-lg">
                    <option value="price_asc" selected="@(Model.SortOrder == "price_asc" || string.IsNullOrWhiteSpace(Model.SortOrder))">Lowest price first</option>
                    <option value="price_desc" selected="@(Model.SortOrder == "price_desc")">Highest price first</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn btn-primary btn-lg px-4">Apply</button>
            </div>

            <div>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Reset</a>
            </div>
        </div>
    </form>

    <form id="antiForgeryForm" method="post">
        @Html.AntiForgeryToken()
    </form>

    @if (Model.Items?.Any() != true)
    {
        <section class="empty-state-card">
            <h3>No confirmed menu items found</h3>
            @if (hasSearch)
            {
                <p>No results matched “@Model.SearchTerm”. Try a different dish, section, menu, or restaurant name.</p>
            }
            else
            {
                <p>Once uploaded menus are processed and marked as ready, they will appear here.</p>
            }
        </section>
    }
    else
    {
        <section class="catalog-table-card">
            <div class="catalog-table-header">
                <div>
                    <h2 class="catalog-table-title">Menu results</h2>
                    <div class="catalog-table-subtitle">
                        Showing @totalItems confirmed @(totalItems == 1 ? "entry" : "entries")
                        @if (hasSearch)
                        {
                            <span>for “@Model.SearchTerm”</span>
                        }
                    </div>
                </div>
                <div class="text-muted small d-none d-md-block">Use the language controls per row</div>
            </div>

            <div class="table-responsive catalog-table-wrapper">
                <table class="table catalog-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Restaurant</th>
                            <th>Menu</th>
                            <th>Section</th>
                            <th>Item</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Translate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="restaurant-name">@item.RestaurantName</div>
                                    <div class="text-muted small">Restaurant</div>
                                </td>
                                <td>
                                    <span class="menu-title-text"
                                          data-original-text="@item.MenuTitle">
                                        @item.MenuTitle
                                    </span>
                                </td>
                                <td>
                                    <span class="section-badge section-text"
                                          data-original-text="@item.Section">
                                        @item.Section
                                    </span>
                                </td>
                                <td>
                                    <span class="item-name-text"
                                          data-original-text="@item.ItemName">
                                        @item.ItemName
                                    </span>
                                </td>
                                <td>
                                    <span class="description-text"
                                          data-original-text="@(item.Description ?? "")">
                                        @(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)
                                    </span>
                                </td>
                                <td>
                                    <span class="price-pill">@item.PriceText</span>
                                </td>
                                <td class="translate-cell">
                                    <div class="translation-panel">
                                        <label class="visually-hidden">Select language</label>
                                        <select class="form-select form-select-sm language-select" aria-label="Select translation language">
                                            <option value="it">Italian</option>
                                            <option value="fr">French</option>
                                            <option value="de">German</option>
                                            <option value="es">Spanish</option>
                                            <option value="mt">Maltese</option>
                                            <option value="en">English</option>
                                            <option value="so">Somali</option>
                                        </select>

                                        <button type="button"
                                                class="btn btn-primary btn-sm translate-btn"
                                                data-restaurant-id="@item.RestaurantId"
                                                data-menu-id="@item.MenuId"
                                                data-item-name="@item.ItemName">
                                            <span class="translate-label">Translate</span>
                                            <span class="translate-loading d-none">Translating...</span>
                                        </button>

                                        <button type="button" class="btn btn-outline-secondary btn-sm reset-btn">Reset</button>
                                        <div class="translation-result" role="status" aria-live="polite"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : "";
            const translateUrl = '@Url.Action("TranslateItem", "Catalog")';

            async function translateText(restaurantId, menuId, text, targetLanguage) {
                if (!text || text.trim() === "" || text.trim() === "-") {
                    return null;
                }

                const body = new URLSearchParams();
                body.append("restaurantId", restaurantId);
                body.append("menuId", menuId);
                body.append("itemName", text);
                body.append("targetLanguage", targetLanguage);

                const response = await fetch(translateUrl, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded",
                        "RequestVerificationToken": token
                    },
                    body: body.toString()
                });

                const json = await response.json();

                if (!json.success) {
                    throw new Error(json.message || "Translation failed");
                }

                return json.translatedText;
            }

            function setTranslationState(button, resultBox, state, message) {
                const label = button.querySelector(".translate-label");
                const loading = button.querySelector(".translate-loading");

                resultBox.classList.remove("success", "error", "working");

                if (state === "working") {
                    button.disabled = true;
                    label.classList.add("d-none");
                    loading.classList.remove("d-none");
                    resultBox.classList.add("working");
                } else {
                    button.disabled = false;
                    label.classList.remove("d-none");
                    loading.classList.add("d-none");

                    if (state === "success") {
                        resultBox.classList.add("success");
                    }

                    if (state === "error") {
                        resultBox.classList.add("error");
                    }
                }

                resultBox.textContent = message || "";
            }

            document.querySelectorAll(".translate-btn").forEach(button => {
                button.addEventListener("click", async function () {
                    const row = button.closest("tr");
                    const translateCell = button.closest("td");

                    const language = translateCell.querySelector(".language-select").value;
                    const resultBox = translateCell.querySelector(".translation-result");

                    const restaurantId = button.dataset.restaurantId;
                    const menuId = button.dataset.menuId;

                    const menuTitleElement = row.querySelector(".menu-title-text");
                    const sectionElement = row.querySelector(".section-text");
                    const itemNameElement = row.querySelector(".item-name-text");
                    const descriptionElement = row.querySelector(".description-text");

                    const originalMenuTitle = menuTitleElement?.dataset.originalText ?? "";
                    const originalSection = sectionElement?.dataset.originalText ?? "";
                    const originalItemName = itemNameElement?.dataset.originalText ?? "";
                    const originalDescription = descriptionElement?.dataset.originalText ?? "";

                    setTranslationState(button, resultBox, "working", "Translating visible fields...");

                    try {
                        const [translatedMenu, translatedSection, translatedItem, translatedDescription] = await Promise.all([
                            translateText(restaurantId, menuId, originalMenuTitle, language),
                            translateText(restaurantId, menuId, originalSection, language),
                            translateText(restaurantId, menuId, originalItemName, language),
                            translateText(restaurantId, menuId, originalDescription, language)
                        ]);

                        if (translatedMenu && menuTitleElement) {
                            menuTitleElement.textContent = translatedMenu;
                        }

                        if (translatedSection && sectionElement) {
                            sectionElement.textContent = translatedSection;
                        }

                        if (translatedItem && itemNameElement) {
                            itemNameElement.textContent = translatedItem;
                        }

                        if (translatedDescription && descriptionElement) {
                            descriptionElement.textContent = translatedDescription;
                        }

                        setTranslationState(button, resultBox, "success", "Translated");
                    } catch (error) {
                        setTranslationState(button, resultBox, "error", "Translation failed: " + error.message);
                    }
                });
            });

            document.querySelectorAll(".reset-btn").forEach(button => {
                button.addEventListener("click", function () {
                    const row = button.closest("tr");

                    const menuTitleElement = row.querySelector(".menu-title-text");
                    const sectionElement = row.querySelector(".section-text");
                    const itemNameElement = row.querySelector(".item-name-text");
                    const descriptionElement = row.querySelector(".description-text");
                    const resultBox = row.querySelector(".translation-result");

                    if (menuTitleElement) {
                        menuTitleElement.textContent = menuTitleElement.dataset.originalText || "";
                    }

                    if (sectionElement) {
                        sectionElement.textContent = sectionElement.dataset.originalText || "";
                    }

                    if (itemNameElement) {
                        itemNameElement.textContent = itemNameElement.dataset.originalText || "";
                    }

                    if (descriptionElement) {
                        const originalDescription = descriptionElement.dataset.originalText || "";
                        descriptionElement.textContent = originalDescription.trim() === "" ? "-" : originalDescription;
                    }

                    if (resultBox) {
                        resultBox.classList.remove("success", "error", "working");
                        resultBox.textContent = "";
                    }
                });
            });
        });
    </script>
}
